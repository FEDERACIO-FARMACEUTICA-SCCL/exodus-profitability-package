        "parameters": [
            {
                "name": "from_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2024-01"
                }
            },
            {
                "name": "to_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2024-12"
                }
            },
            {
