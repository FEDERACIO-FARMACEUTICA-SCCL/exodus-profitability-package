{
	"name": "fedefarma/exodus-profitability-package",
	"description": "Exodus profitability package for Laravel",
	"type": "library",
	"require": {
		"php": "^8.2",
		"laravel/framework": "^8.75|^9.2|^10.0|^11.0|^12.0|^13.0"
	},
	"require-dev": {
		"labelgrup/laravel-utilities": "dev-master",
		"laravel/passport": "^12.0",
		"laravel/pint": "^1.16",
		"orchestra/testbench": "^9.0",
		"phpunit/phpunit": "^10.0|^11.0"
	},
	"license": "MIT",
	"autoload": {
		"psr-4": {
			"ProfitabilityExodus\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"ProfitabilityExodus\\Test\\": "tests/"
		}
	},
	"authors": [
		{
			"name": "Eric RF",
			"email": "erojas@labelgrup.com"
		}
	],
	"minimum-stability": "stable",
	"config": {
		"sort-packages": true
	},
	"prefer-stable": true,
	"extra": {
		"laravel": {
			"providers": [
				"ProfitabilityExodus\\ProfitabilityExodusServiceProvider"
			]
		}
	}
}
