{
    "get": {
        "tags": [
            "Discounts"
        ],
        "summary": "Export generics discounts to Excel",
        "operationId": "ExportDiscountsGenerics",
        "parameters": [
            {
                "name": "from_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2025-01"
                }
            },
            {
                "name": "to_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2025-11"
                }
            },
            {
                "name": "organization_identifier",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "string",
                    "example": "S77776"
                }
            },
            {
                "name": "search_query",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "string"
                }
            }
        ],
        "responses": {
            "200": {
                "description": "Excel file download",
                "content": {
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                        "schema": {
                            "type": "string",
                            "format": "binary"
                        }
                    }
                }
            },
            "422": {
                "$ref": "../../../../shared/responses/ValidationError.json"
            },
            "424": {
                "$ref": "../../../../shared/responses/FailedDependency.json"
            },
            "500": {
                "$ref": "../../../../shared/responses/InternalServerError.json"
            }
        }
    }
}