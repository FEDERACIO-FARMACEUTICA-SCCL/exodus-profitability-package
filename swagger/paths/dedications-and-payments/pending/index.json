{
    "get": {
        "tags": [
            "Dedications & Payments"
        ],
        "summary": "Get pending payments details",
        "operationId": "GetPendingPaymentsDetails",
        "parameters": [
            {
                "name": "from_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2024-01"
                }
            },
            {
                "name": "to_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2024-12"
                }
            },
            {
                "name": "organization_identifier",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "string"
                }
            },
            {
                "name": "page",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "integer",
                    "example": 1
                }
            },
            {
                "name": "per_page",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "integer",
                    "example": 10
                }
            }
        ],
        "responses": {
            "200": {
                "description": "Pending payments details",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "items": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "amount_status": {
                                                "type": "string",
                                                "example": "PENDING"
                                            },
                                            "date": {
                                                "type": "string",
                                                "format": "date-time"
                                            },
                                            "delivery_note": {
                                                "type": "string",
                                                "example": "DN-0001"
                                            },
                                            "laboratory": {
                                                "type": "string",
                                                "example": "Lab A"
                                            },
                                            "laboratory_name": {
                                                "type": "string",
                                                "example": "Laboratory A"
                                            },
                                            "amount": {
                                                "type": "number",
                                                "format": "float",
                                                "example": 999.99
                                            }
                                        }
                                    }
                                },
                                "total_count": {
                                    "type": "integer",
                                    "example": 2
                                },
                                "page": {
                                    "type": "integer",
                                    "example": 1
                                },
                                "page_size": {
                                    "type": "integer",
                                    "example": 10
                                },
                                "total_pages": {
                                    "type": "integer",
                                    "example": 1
                                }
                            }
                        }
                    }
                }
            },
            "422": {
                "$ref": "../../../shared/responses/ValidationError.json"
            },
            "424": {
                "$ref": "../../../shared/responses/FailedDependency.json"
            },
            "500": {
                "$ref": "../../../shared/responses/InternalServerError.json"
            }
        }
    }
}