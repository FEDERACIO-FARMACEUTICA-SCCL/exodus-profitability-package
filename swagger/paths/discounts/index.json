{
    "get": {
        "tags": [
            "Discounts"
        ],
        "summary": "Get discounts summary data",
        "operationId": "GetDiscounts",
        "parameters": [
            {
                "name": "from_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2025-01"
                }
            },
            {
                "name": "to_month",
                "in": "query",
                "required": true,
                "schema": {
                    "type": "string",
                    "example": "2025-11"
                }
            },
            {
                "name": "organization_identifier",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "string",
                    "example": "S77776"
                }
            }
        ],
        "responses": {
            "200": {
                "description": "Discounts summary data",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "company_discount": {
                                    "type": "number",
                                    "format": "float",
                                    "example": 9999.99
                                },
                                "company_discount_percentage": {
                                    "type": "number",
                                    "format": "float",
                                    "example": 99.9
                                }
                            }
                        }
                    }
                }
            },
            "422": {
                "$ref": "../../shared/responses/ValidationError.json"
            },
            "424": {
                "$ref": "../../shared/responses/FailedDependency.json"
            },
            "500": {
                "$ref": "../../shared/responses/InternalServerError.json"
            }
        }
    }
}